# Required: the LLM agents (Director, Quant, Execution) run on this.
OPENAI_API_KEY=

# Jupiter API (token price & search tools; raises rate limits)
# Get a key at https://portal.jup.ag
JUPITER_API_KEY=

# Only needed if you explicitly call autohedge.live.execute_live_swap()
# yourself with AUTOHEDGE_ENABLE_LIVE_TRADING set. Base58-encoded Solana
# keypair. Never commit a real value here.
SOLANA_PRIVATE_KEY=