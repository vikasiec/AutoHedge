# Required: the LLM agents (Director, Quant, Execution) run on this.
# Set OPENAI_API_KEY (default) OR switch providers with AUTOHEDGE_MODEL
# below and set the matching key instead.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional: which model the agents use. Default is "gpt-4.1" (OpenAI).
# To use Gemini instead, set this to a LiteLLM Gemini model id and set
# GEMINI_API_KEY above instead of OPENAI_API_KEY, e.g.:
# AUTOHEDGE_MODEL=gemini/gemini-2.5-flash
# AUTOHEDGE_LIGHT_MODEL=gemini/gemini-2.5-flash
AUTOHEDGE_MODEL=
AUTOHEDGE_LIGHT_MODEL=

# Jupiter API (token price & search tools; raises rate limits)
# Get a key at https://portal.jup.ag
JUPITER_API_KEY=

# Only needed if you explicitly call autohedge.live.execute_live_swap()
# yourself with AUTOHEDGE_ENABLE_LIVE_TRADING set. Base58-encoded Solana
# keypair. Never commit a real value here.
SOLANA_PRIVATE_KEY=